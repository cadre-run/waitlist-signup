---
interface Props {
  code: string;
  position: number;
}

const { code, position } = Astro.props;
const badgeUrl = `/api/badge/${code}`;
const siteUrl = import.meta.env.SITE_URL || 'https://cadre.run';

const shareUrl = `${siteUrl}/r/${code}`;
const tweetText = encodeURIComponent(`I'm #${position} on the @runcadre waitlist. Your AI team, deployed in minutes.\n\nJoin → ${shareUrl}`);
---

<div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
  <h3 class="text-base font-semibold text-[var(--color-text-primary)] mb-4">Your waitlist badge</h3>

  <div class="rounded-[var(--radius-md)] overflow-hidden max-w-[320px] mx-auto mb-5">
    <object
      data={badgeUrl}
      type="image/svg+xml"
      class="w-full"
      style="aspect-ratio: 1/1;"
      id="badge-svg"
    >
      <img src={badgeUrl} alt={`Waitlist position #${position}`} class="w-full" />
    </object>
  </div>

  <p class="text-center text-sm text-[var(--color-text-tertiary)] mb-5">
    Download your badge as PNG, then attach it when sharing.
  </p>

  <div class="flex gap-3">
    <button
      id="download-badge"
      class="flex-1 text-center px-4 py-2.5 rounded-[var(--radius-sm)] border border-[var(--color-border)] text-sm font-medium text-[var(--color-text-primary)] hover:bg-white transition-colors cursor-pointer"
      style="transition-duration: var(--duration-fast);"
    >
      <svg class="w-4 h-4 inline-block mr-1.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
      Download PNG
    </button>
    <a
      href={`https://x.com/intent/tweet?text=${tweetText}`}
      target="_blank"
      rel="noopener"
      class="flex-1 text-center px-4 py-2.5 rounded-[var(--radius-sm)] bg-[var(--color-text-primary)] text-white text-sm font-medium hover:bg-[var(--color-text-primary)]/90 transition-colors cursor-pointer"
      style="transition-duration: var(--duration-fast);"
    >
      Share on X
    </a>
  </div>
</div>

<script is:inline data-badge-url={badgeUrl} data-position={String(position)}>
(function() {
  var script = document.currentScript;
  var badgeUrl = script.getAttribute('data-badge-url');
  var position = script.getAttribute('data-position');

  document.getElementById('download-badge').addEventListener('click', function() {
    var btn = this;
    btn.textContent = 'Generating…';

    fetch(badgeUrl)
      .then(function(r) { return r.text(); })
      .then(function(svgText) {
        var blob = new Blob([svgText], { type: 'image/svg+xml' });
        var url = URL.createObjectURL(blob);
        var img = new Image();
        img.onload = function() {
          var canvas = document.createElement('canvas');
          canvas.width = 1200;
          canvas.height = 1200;
          var ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, 1200, 1200);
          URL.revokeObjectURL(url);

          canvas.toBlob(function(pngBlob) {
            var pngUrl = URL.createObjectURL(pngBlob);
            var a = document.createElement('a');
            a.href = pngUrl;
            a.download = 'cadre-waitlist-' + position + '.png';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(pngUrl);
            btn.textContent = 'Download PNG';
          }, 'image/png');
        };
        img.src = url;
      });
  });
})();
</script>
