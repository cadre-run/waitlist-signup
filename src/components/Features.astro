---
const v1Features = [
  { text: 'Automated server provisioning', detail: 'Hetzner, Netcup, DigitalOcean — your server, your data' },
  { text: 'Server hardening', detail: 'SSH, Firewall, Fail2ban, auto-updates — production-secure from day one' },
  { text: 'Containerized Paperclip', detail: 'Docker Compose with NGINX, SSL, and persistent volumes pre-configured' },
  { text: 'Token optimization engine', detail: '60% fewer tokens via prompt interception in the adapter execution path' },
  { text: 'Intelligent model routing', detail: 'Automatically picks the cheapest capable model per task — Flash Lite for simple work, Pro for complex reasoning' },
  { text: 'Gemini CLI + Claude Code support', detail: 'Use $20/month subscriptions instead of $400+/month API costs' },
  { text: 'Department-based RBAC', detail: 'Granular permissions per business unit with budget controls per agent' },
  { text: 'Agent heartbeat monitoring', detail: 'Real-time cost tracking, automatic pause at budget limits' },
];

const roadmapFeatures = [
  'Vision Board',
  'Agentic DMS Module',
  'Integration Hub / Module Marketplace',
  'HR Module',
  'Automated backups & monitoring dashboard',
  'Multi-provider agent support',
];
---

<section class="relative bg-[var(--color-surface)] py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6">

    <div class="text-center mb-16 animate-on-scroll">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider mb-3">Features</p>
      <h2 class="text-3xl lg:text-4xl font-semibold tracking-[-0.03em] text-[var(--color-text-primary)]">
        Beyond vanilla Paperclip
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 max-w-5xl mx-auto">

      <!-- v1 -->
      <div class="animate-on-scroll delay-1">
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-primary text-white tracking-wide">
            v1
          </span>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">Included at launch</h3>
        </div>

        <div class="space-y-5">
          {v1Features.map((feature) => (
            <div class="flex items-start gap-3.5">
              <div class="mt-0.5 w-5 h-5 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              </div>
              <div>
                <span class="text-[var(--color-text-primary)] font-medium">{feature.text}</span>
                {feature.detail && (
                  <span class="text-[var(--color-text-tertiary)] text-sm ml-1">– {feature.detail}</span>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Roadmap -->
      <div class="animate-on-scroll delay-2">
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-[var(--color-border)] text-[var(--color-text-secondary)] tracking-wide">
            ROADMAP
          </span>
          <h3 class="text-lg font-semibold text-[var(--color-text-secondary)]">Coming soon</h3>
        </div>

        <div class="space-y-5">
          {roadmapFeatures.map((feature) => (
            <div class="flex items-start gap-3.5 opacity-50">
              <div class="mt-0.5 w-5 h-5 rounded-full border border-[var(--color-border)] flex items-center justify-center shrink-0">
                <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-border)]"></div>
              </div>
              <span class="text-[var(--color-text-secondary)]">{feature}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
