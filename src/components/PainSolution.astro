---
const cards = [
  {
    pain: 'Docker + VPS + .env = hours of debugging',
    solution: 'Fill out a form. Your server is provisioned, hardened, ready.',
    detail: 'Vanilla Paperclip needs Docker, Postgres, SSL, persistent volumes, and security hardening (Fail2ban, UFW, auto-updates). Gemini CLI isn\'t even in the default Docker image. Cadre handles all of it.',
    metric: 'Under 5 minutes',
    metricLabel: 'Setup time',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" /></svg>`,
    gradient: 'from-primary/10 to-violet-500/5',
  },
  {
    pain: 'AI agents burn through tokens like there\'s no tomorrow',
    solution: 'Pre-optimized prompting system. Same output, fraction of the cost.',
    detail: 'A single Gemini Pro agent costs ~$1,755/month via API. Cadre\'s token optimization + intelligent model routing brings that down to ~$89/month — same results, 95% less spend.',
    metric: 'Up to 60%',
    metricLabel: 'fewer tokens',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>`,
    gradient: 'from-amber-500/10 to-orange-500/5',
  },
  {
    pain: 'No visibility into what your agents actually do and cost',
    solution: 'Dashboard with heartbeats, budgets, department controls, live status.',
    detail: 'Without budget controls, a single agent can burn $400+ in hours. Cadre enforces per-agent and per-company budgets with automatic pause at hard limits — runaway costs are structurally impossible.',
    metric: 'Real-time',
    metricLabel: 'cost tracking',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>`,
    gradient: 'from-emerald-500/10 to-teal-500/5',
  },
];
---

<section class="relative bg-[var(--color-surface)] py-28 lg:py-36 overflow-hidden">
  <!-- Subtle dot pattern -->
  <div class="absolute inset-0 bg-dots opacity-40 pointer-events-none" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-6">

    <div class="text-center mb-16 lg:mb-20 animate-on-scroll">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider mb-3">The Problem</p>
      <h2 class="text-3xl lg:text-[2.75rem] font-bold tracking-[-0.03em] text-[var(--color-text-primary)]">
        Why self-hosting Paperclip is painful.
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        We solved the three biggest pain points so you can focus on what matters.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {cards.map((card, i) => (
        <div
          class:list={[
            'card-premium group relative p-8 lg:p-10',
            'transition-all hover:shadow-[var(--shadow-lg)] hover:-translate-y-1',
            'animate-on-scroll',
            `delay-${i + 1}`,
          ]}
          style="transition-duration: var(--duration-slow);"
        >
          <!-- Gradient background on hover -->
          <div class:list={['absolute inset-0 rounded-[var(--radius-lg)] bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity', card.gradient]} style="transition-duration: var(--duration-slow);" aria-hidden="true"></div>

          <div class="relative">
            <!-- Icon -->
            <div class="w-12 h-12 rounded-[var(--radius-md)] bg-primary/8 text-primary flex items-center justify-center mb-6 transition-all group-hover:bg-primary/15 group-hover:shadow-[0_0_20px_rgba(79,70,229,0.1)]" style="transition-duration: var(--duration-normal);">
              <Fragment set:html={card.icon} />
            </div>

            <!-- Pain -->
            <p class="text-[var(--color-text-tertiary)] line-through decoration-[var(--color-border)] text-sm mb-3">
              {card.pain}
            </p>

            <!-- Solution -->
            <p class="text-[var(--color-text-primary)] font-medium text-base leading-snug mb-3">
              {card.solution}
            </p>

            <!-- Detail -->
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-8">
              {card.detail}
            </p>

            <!-- Metric - big number treatment -->
            <div class="pt-6 border-t border-[var(--color-border-light)]">
              <span class="text-2xl font-bold text-gradient">{card.metric}</span>
              <span class="text-sm text-[var(--color-text-tertiary)] ml-2">{card.metricLabel}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
