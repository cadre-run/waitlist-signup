---

<footer class="bg-white border-t border-[var(--color-border)] py-12">
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">

      <!-- Logo -->
      <img src="/images/logo-wordmark.svg" alt="Cadre" class="h-8 w-auto" />

      <!-- Links -->
      <div class="flex items-center gap-8 text-sm text-[var(--color-text-tertiary)]">
        <a href="/privacy" class="hover:text-[var(--color-text-primary)] transition-colors cursor-pointer" style="transition-duration: var(--duration-fast);">Privacy</a>
        <a href="/terms" class="hover:text-[var(--color-text-primary)] transition-colors cursor-pointer" style="transition-duration: var(--duration-fast);">Terms</a>
        <a href="https://x.com/cadre" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-text-primary)] transition-colors cursor-pointer" style="transition-duration: var(--duration-fast);">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>

      <!-- Info -->
      <div class="text-xs text-[var(--color-text-tertiary)] text-center md:text-right">
        <p>Built in Germany &middot; Powered by Paperclip (MIT)</p>
        <p class="mt-1">&copy; 2026 Cadre</p>
      </div>

    </div>
  </div>
</footer>
