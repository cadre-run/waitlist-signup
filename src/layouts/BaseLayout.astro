---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'Cadre – Managed Paperclip Hosting | Your AI Company in Minutes',
  description = 'Managed Paperclip hosting with 60% token optimization and intelligent routing. Deploy your AI company on your own server in minutes. No Docker needed.',
  ogImage = '/images/og-share.png',
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

import '../styles/global.css';

// Structured data for the landing page
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Cadre',
  url: 'https://cadre.run',
  description: 'Managed Paperclip hosting with 60% token optimization, intelligent routing, and vertical modules. Deploy your AI company on your own server in minutes.',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Cloud',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/PreOrder',
  },
  creator: {
    '@type': 'Organization',
    name: 'Cadre',
    url: 'https://cadre.run',
  },
};

// Organization structured data
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Cadre',
  url: 'https://cadre.run',
  logo: 'https://cadre.run/images/logo-icon.png',
  description: 'Managed Paperclip hosting platform with token optimization, intelligent routing, and vertical AI modules.',
  foundingDate: '2026',
  sameAs: [
    'https://x.com/runcadre',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    url: 'https://cadre.run',
  },
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'DE',
  },
};

// FAQ structured data for rich snippets
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does it actually cost to run AI agents?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A 24/7 Gemini Pro agent costs ~$1,755/month via raw API. With Cadre\'s token optimization and intelligent model routing, that drops to ~$89/month. With a Google AI Pro subscription ($20/month), your marginal cost approaches zero.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is Cadre different from PaperclipCloud?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'PaperclipCloud deploys vanilla Paperclip — it\'s hosting. Cadre is a platform: 60% token optimization, intelligent multi-model routing, subscription support, server hardening, and vertical modules for content creation and document management.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need my own API keys?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'You can use either API keys or CLI subscriptions. Cadre supports Gemini CLI (Google AI Pro from $20/month), Claude Code, and Codex. Subscriptions are 5-10x cheaper than API keys for 24/7 usage.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where does my data live?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'On your own server, with the hosting provider you choose (Hetzner, Netcup, DigitalOcean). One dedicated node per tenant with full data isolation. Cadre never stores your data.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is this based on Paperclip?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Cadre builds on Paperclip\'s open-source foundation (MIT) with surgical patches for token optimization and quota-aware model selection, plus separate packages for everything else. We sync upstream every 2-4 weeks.',
      },
    },
    {
      '@type': 'Question',
      name: 'What about security? Paperclip has no rate limiting.',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Vanilla Paperclip has no rate limiting, no security headers, and runs in local trusted mode by default. Cadre adds NGINX with SSL, rate limiting, security headers, SSH hardening (Fail2ban, UFW), and automatic security updates.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which AI providers and models are supported?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Gemini CLI (Flash Lite, Flash, Pro), Claude Code (Haiku, Sonnet, Opus), and Codex. Cadre\'s intelligent routing automatically picks the cheapest model capable of each task.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does Cadre itself cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Pricing is not finalized yet. Join the waitlist for founding member pricing. You\'ll pay for infrastructure management only — no per-token markup.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I migrate from my existing Paperclip setup?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Cadre runs Paperclip under the hood, so your existing companies, agents, goals, and configurations are compatible. Migration path available at launch.',
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Cadre" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@runcadre" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="128x128" href="/images/logo-icon.png" />
    <link rel="apple-touch-icon" href="/images/logo-icon.png" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

    <!-- Theme color for mobile browsers -->
    <meta name="theme-color" content="#4F46E5" />
  </head>
  <body class="bg-white overflow-x-hidden">
    <slot />

    <!-- Scroll animation observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });
    </script>

    <!-- Cloudflare Web Analytics -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "41c6cef329b440089469863bfe88be8a"}'></script>
  </body>
</html>
